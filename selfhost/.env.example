# Portfolio98 — copy this to .env and fill in real values
# Run setup.sh to generate .env automatically.

# PostgreSQL connection string
DATABASE_URL=postgresql://portfolio98:yourpassword@localhost:5432/portfolio98

# Random secret for session cookies (run: openssl rand -hex 32)
SESSION_SECRET=replace_with_random_secret

# Port to serve on (API + frontend served from same port)
PORT=3000

# Set to 1 to serve the built frontend alongside the API (self-host mode)
SERVE_STATIC=1

# production | development
NODE_ENV=production
